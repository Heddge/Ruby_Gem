module CLIDownloader
  VERSION: String

  class Error < ::StandardError
  end

  class Tagger
    TAG_SIGNATURE: String
    TAG_SIZE: Integer
    SUPPORTED_EXTENSIONS: Array[String]
    METADATA_KEYS: Array[Symbol]
    GENRES: Array[String]

    def tag: (String file_path, ?::Hash[Symbol | String, untyped] metadata) -> ::Hash[Symbol, untyped]
    def write: (String file_path, ?::Hash[Symbol | String, untyped] metadata) -> ::Hash[Symbol, untyped]
    def update: (String file_path, ?::Hash[Symbol | String, untyped] metadata) -> ::Hash[Symbol, untyped]
    def read: (String file_path) -> ::Hash[Symbol, untyped]
    def tag_present?: (String file_path) -> bool
  end

  class Tagger::TaggerError < ::StandardError
  end

  class Tagger::UnsupportedFormatError < Tagger::TaggerError
  end

  class Fetcher
    DEFAULT_OUTPUT_TEMPLATE: String

    class Result < ::Struct
      attr_accessor source_url: String
      attr_accessor file_path: String
      attr_accessor strategy: Symbol
      attr_accessor stdout: String
      attr_accessor stderr: String

      def filename: () -> String
    end

    def initialize: (?output_directory: String, ?yt_dlp_bin: String, ?runner: untyped) -> void
    def download: (
      String url,
      ?filename: String?,
      ?output_template: String,
      ?force_strategy: Symbol?,
      ?headers: ::Hash[String | Symbol, untyped]
    ) -> Result
  end

  class Fetcher::FetcherError < Error
  end

  class Fetcher::InvalidURLError < Fetcher::FetcherError
  end

  class Fetcher::DownloadFailedError < Fetcher::FetcherError
    attr_reader exit_status: Integer?
  end

  class Fetcher::MissingDependencyError < Fetcher::FetcherError
  end

  class CLI
    def self.start: (
      ?::Array[String] argv,
      ?out: untyped,
      ?err: untyped,
      ?fetcher_factory: singleton(Fetcher)
    ) -> Integer

    def initialize: (
      ::Array[String] argv,
      out: untyped,
      err: untyped,
      fetcher_factory: singleton(Fetcher)
    ) -> void

    def start: () -> Integer
  end

end
